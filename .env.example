CMS_URL=http://localhost:3000
CMS_API_KEY=your-readonly-api-key
TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
WEBHOOK_SECRET=your-webhook-secret
# CDN HTML: revalidate (invalidar solo al publicar/webhook) | edge-ttl (TTL largo en borde)
CDN_HTML_CACHE_MODE=revalidate
CDN_HTML_S_MAXAGE_SECONDS=86400
NODE_ENV=development
